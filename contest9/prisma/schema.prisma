generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  role      Role
  wallet    Int        @default(0)

  courses   Course[]   @relation("AdminCourses")
  purchases Purchase[]
}

model Course {
  id           Int        @id @default(autoincrement())
  title        String
  description  String
  price        Int

  createdById  Int
  createdBy    User       @relation("AdminCourses", fields: [createdById], references: [id])

  purchases    Purchase[]
}

model Purchase {
  id        Int      @id @default(autoincrement())

  userId    Int
  courseId  Int

  user       User     @relation(fields: [userId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}